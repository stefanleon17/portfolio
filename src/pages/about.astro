---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { SITE_DATA } from "../constants";
import portraitImage from "../assets/portrait.jpg";

import "../styles/about.css";
---

<Layout pageTitle="About">
    <div class="page-container">
        <h1>About me</h1>

        <div class="about-content">
            <div class="about-intro-wrapper centered-column">
                <div class="about-header centered-column">
                    <Image
                        src={portraitImage}
                        alt={SITE_DATA.name}
                        class="about-portrait"
                    />
                    <!--  Removed name  -->
                    <!-- <h2 class="about-name">{SITE_DATA.name}</h2> -->
                </div>

                <p class="intro-text">
                    I am an HCI student, with a background in Computer Science
                    and Psychology. I enjoy looking at the way people and
                    technology interact, and the way we can make software
                    products that are actually useful and beneficial for people.
                </p>
            </div>

            <section>
                <h2>Research Interest</h2>
                <div class="info-card">
                    <p>Placeholder</p>
                </div>
            </section>

            <section>
                <h2>Research Projects</h2>
                <ul class="custom-list">
                    <li>
                        <span class="list-item-title"
                            >Learning through Learning Management Systems:
                            Exploring the experiences of students using
                            Brightspace as a tool in their academic activities</span
                        >
                        <span class="list-item-description"
                            >A qualitative study exploring the experiences of
                            students using Brightspace as a tool in their
                            academic activities, through semi-structured
                            interviews and observational studies. This research
                            aims to help inform universities and decision makers
                            on how to better structure their LMS implementation,
                            in order to effectively improve students’ learning
                            experience.
                        </span>
                    </li>
                    <li>
                        <span class="list-item-title"
                            >Hé Ally: the effect of region-specific elements in
                            digital advertising on customer interaction</span
                        >
                        <span class="list-item-description"
                            >This study investigated the effectiveness of
                            geotargeted online advertising, specifically the use
                            of region-specific textual and visual elements, on
                            click-through rates (CTR) for a regional internet
                            service provider in the Netherlands. Using Google
                            Ads, geotargeted and non-geotargeted advertisements
                            were simultaneously served to users in the Almere
                            region over a two-week period. A two-sample t-test,
                            logistic regression, and ANOVA were performed to
                            evaluate the effect of geotargeting while accounting
                            for demographic variables and device types.</span
                        >
                    </li>
                    <li>
                        <span class="list-item-title"
                            >The Effect of Added Thermal-Tactile Modality on
                            Presence and Immersion in Virtual Reality</span
                        >
                        <span class="list-item-description"
                            >This paper investigates the effects of ambient
                            thermal feedback, specifically heated airflow, on
                            user presence and immersion within a virtual reality
                            desert environment. A within-subjects study with
                            five participants was conducted to compare a
                            baseline audiovisual condition against an
                            audiovisual-plus-thermal condition using a
                            directional heated fan depending on the user’s
                            virtual position.</span
                        >
                    </li>
                </ul>
            </section>

            <section>
                <h2>Positions</h2>
                <ul class="work-list icon-list">
                    <li>
                        <div class="list-entry">
                            <h3>Research Assistant, EcoBUILD</h3>
                            <p class="institution">
                                Utrecht University, December 2025 - April 2026
                            </p>
                            <p>
                                Contributed to a research project focused on
                                visualizing sustainable building design
                                strategies, using academic literature to inform
                                and validate the work. Developed and maintained
                                a static website with Astro and built a
                                prompt-based Retrieval-Augmented Generation
                                (RAG) pipeline to extract and structure
                                knowledge from research papers.
                            </p>
                        </div>
                    </li>
                    <li>
                        <div class="list-entry">
                            <h3>Research Assistant, PRIONOMICS</h3>
                            <p class="institution">
                                Utrecht University, May 2026 - present
                            </p>
                            <p>
                                Contributed to a medical data visualization
                                project focused on Creutzfeldt-Jakob disease
                                (CJD), developing interactive analyses by
                                combining Parallel Coordinates Plots (PCP) and
                                UpSet plots to explore patterns and
                                relationships within prion disease datasets.
                            </p>
                        </div>
                    </li>
                </ul>
            </section>

            <section>
                <h2>Education</h2>
                <ul class="education-list icon-list">
                    <li>
                        <div class="education-entry">
                            <h3>MSc in Human-Computer Interaction</h3>
                            <p class="institution">
                                Utrecht University, 2024 - 2026
                            </p>
                            <p class="grade">Expected Graduation: 2026</p>
                        </div>
                    </li>
                    <li>
                        <div class="education-entry">
                            <h3>BSc in Computer Science and Psychology</h3>
                            <p class="institution">
                                American University in Bulgaria, 2020 - 2024
                            </p>
                            <p class="grade">Graduated summa cum laude</p>
                            <p class="thesis">
                                <b>Computer Science Thesis:</b>
                                <em
                                    >"ChatAUBG: A Chatbot for Navigating a
                                    University Website"</em
                                >
                            </p>
                            <p class="thesis">
                                <b>Psychology Thesis:</b>
                                <em
                                    >"Should You Try Harder? – the Relationship
                                    Between Cognitive Effort and Performance, as
                                    Mediated by Perceived Difficulty"</em
                                >
                            </p>
                        </div>
                    </li>
                </ul>
            </section>

